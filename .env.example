# ─────────────────────────────────────────────────────────────────────────────
# .env.example — Safe template. Copy this to .env and fill in real values.
# NEVER commit your actual .env file.
# ─────────────────────────────────────────────────────────────────────────────

# MongoDB Atlas connection string
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/walrus?retryWrites=true&w=majority

# Google Gemini API key (https://ai.google.dev)
GEMINI_API_KEY=your_gemini_api_key_here

# Groq API key (optional fallback AI)
GROQ_API_KEY=your_groq_api_key_here

# JWT signing secret — use a long random string (min 32 chars)
JWT_SECRET=replace_this_with_a_long_random_secret_string

# Backend port (default: 5000)
PORT=5000

# Frontend URL (used for CORS in production)
# e.g. https://walrus-frontend.onrender.com
FRONTEND_URL=http://localhost:5173

# Frontend: backend API URL (used by Vite at build time)
VITE_API_URL=http://localhost:5000/api
